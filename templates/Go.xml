<templateSet group="Go">
  <template name="errn" value="if err != nil {&#10;    return $RETURN_VALUE$, err&#10;}" description="Check err and return it" toReformat="true" toShortenFQNames="true">
    <variable name="RETURN_VALUE" expression="" defaultValue="nil" alwaysStopAt="true" />
    <context>
      <option name="GO" value="true" />
    </context>
  </template>
  <template name="json" value="`json:&quot;$NAME$&quot;`" description="JSON struct tag" toReformat="false" toShortenFQNames="true">
    <variable name="NAME" expression="camelCase(goVarName())" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="GO" value="true" />
    </context>
  </template>
  <template name="tf" value="func Test$NAME$(t *testing.T) {&#10;    $END$&#10;}" description="Test function" toReformat="true" toShortenFQNames="true">
    <variable name="NAME" expression="" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="GO" value="true" />
    </context>
  </template>
</templateSet>
